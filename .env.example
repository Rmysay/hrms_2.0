# IKDS — Environment Variables
# Kopyalayın: cp .env.example .env
# Değerleri doldurun ve .env dosyasını asla commit etmeyin!

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/ikds_db
DB_USERNAME=ikds_user
DB_PASSWORD=your_secure_password_here

# JWT (min 256-bit / 32 karakter)
JWT_SECRET=your-minimum-256-bit-secret-key-here-change-this
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# CORS
CORS_ORIGINS=http://localhost:5173
